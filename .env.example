# Copy to `.env` (or `.env.local`, which is gitignored) and adjust.
#
# Base URL of the lms-spring backend. Expo inlines EXPO_PUBLIC_* vars into the
# bundle. From a physical phone, use your laptop's LAN IP (not localhost):
#   Windows: ipconfig | findstr IPv4
#
# Examples:
#   EXPO_PUBLIC_API_BASE_URL=http://192.168.1.50:8080
#   EXPO_PUBLIC_API_BASE_URL=https://<your-ngrok-subdomain>.ngrok-free.app
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
